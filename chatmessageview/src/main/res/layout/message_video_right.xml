<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/message_text_shape_right"
    android:padding="@dimen/spacing_micro">

    <com.github.bassaer.chatmessageview.view.RoundImageView
        android:id="@+id/message_video_thumbnail"
        android:layout_width="@dimen/width_normal"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:src="@color/blueGray200" />

    <ImageView
        android:id="@+id/message_video_play"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:background="@drawable/message_video_play_background"
        android:contentDescription="@string/chat_video_message"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_play" />

</FrameLayout>
