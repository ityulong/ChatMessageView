<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_line">

    <ProgressBar
        android:id="@+id/message_transfer_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_line"
        android:layout_marginRight="@dimen/spacing_line"
        android:max="100"/>

    <TextView
        android:id="@+id/message_transfer_progress_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/chat_transfer_completed"
        android:textSize="@dimen/font_small"/>

</LinearLayout>
